GROQ_API_KEY=""
FLASK_SECRET_KEY=your-secret-key-here-make-it-random

# Google OAuth (REAL CREDENTIALS)
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# OAuth Security Settings (required for local development)
OAUTHLIB_INSECURE_TRANSPORT=1
OAUTHLIB_RELAX_TOKEN_SCOPE=1

# Development mode (set to false when you have real credentials)
DEV_MODE=false